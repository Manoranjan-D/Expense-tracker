# --- Expo public env (safe to expose to the client) ------------------------
# Found in: Supabase dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Edge Function secret (NOT public) -------------------------------------
# Set this with the Supabase CLI, do not put it in the client bundle:
#   supabase secrets set GOOGLE_VISION_API_KEY=your-key
# Optional: if unset, the parse-receipt function uses a built-in mock parser.
# GOOGLE_VISION_API_KEY=your-google-cloud-vision-api-key
